{
  "name": "n8n-nodes-microlink",
  "version": "0.1.0",
  "description": "Microlink.io integration for n8n",
  "license": "MIT",
  "keywords": [
    "n8n-community-node-package",
    "microlink",
    "n8n"
  ],
  "author": {
    "name": "Microlink",
    "email": "support@microlink.io"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/microlinkhq/n8n-nodes-microlink.git"
  },
  "scripts": {
    "lint": "eslint nodes credentials package.json",
    "build": "rm -rf dist && tsc --project tsconfig.json && mkdir -p dist/nodes/Microlink && cp nodes/Microlink/microlink.svg dist/nodes/Microlink/microlink.svg",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/MicrolinkApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Microlink/Microlink.node.js"
    ]
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.18.6",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "9.32.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.7",
    "jest": "^30.3.0",
    "jsonc-eslint-parser": "^3.1.0",
    "ts-jest": "^29.4.1",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
